---
import { Icon } from 'astro-icon/components';
import Button from '@/components/Button.astro';
import CurioHeroDemo from '@/components/CurioHeroDemo.astro';
import { curioCourses } from '@/data/site';

const live = curioCourses.filter((c) => c.liveUrl);
const totalScenes = curioCourses.reduce((a, c) => a + c.scenes, 0);
const demos = [
  { id: 'orbit', title: 'Gravity & orbits', course: 'Cosmos', body: 'Why the Moon never falls down — watch velocity and gravity balance into an orbit.' },
  { id: 'prism', title: 'Light through a prism', course: 'Prism', body: 'White light bends, splits, and fans into a spectrum — refraction you can see.' },
  { id: 'circuit', title: 'Current in a circuit', course: 'Volta', body: 'Electrons drift around a loop and a lamp glows brighter as the current rises.' },
];
---

<CurioHeroDemo />

<!-- Live mini-demos: the Curio feel, rendered right here -->
<section class="border-t border-line py-20 md:py-28">
  <div class="container-app">
    <span class="eyebrow reveal"><span class="size-1.5 rounded-full bg-teal"></span>See it move</span>
    <h2 class="reveal mt-5 text-3xl md:text-4xl" data-delay="1">Concepts that <span class="text-gradient">come alive</span></h2>
    <p class="reveal mt-4 max-w-2xl text-muted" data-delay="2">
      This is the Curio method in miniature — three live simulations running right on this page, the
      same way every scene in every course moves. No walls of text. Just physics doing its thing.
    </p>

    <div class="mt-12 grid gap-4 lg:grid-cols-3">
      {demos.map((d, i) => (
        <figure
          class="reveal group overflow-hidden rounded-3xl border border-line bg-surface/40 transition-all duration-300 hover:-translate-y-1 hover:border-line-strong"
          data-delay={String(i + 1)}
        >
          <div class="relative aspect-[4/3] bg-canvas-deep">
            <canvas data-demo={d.id} class="absolute inset-0 size-full"></canvas>
          </div>
          <figcaption class="border-t border-line p-6">
            <div class="flex items-center justify-between gap-3">
              <h3 class="text-lg">{d.title}</h3>
              <span class="shrink-0 rounded-full border border-line bg-white/[0.02] px-2.5 py-1 font-mono text-[0.6rem] uppercase tracking-[0.14em] text-faint">from {d.course}</span>
            </div>
            <p class="mt-2 text-sm leading-relaxed text-muted">{d.body}</p>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<!-- Catalog -->
<section class="border-t border-line py-20 md:py-28">
  <div class="container-app">
    <div class="flex flex-wrap items-end justify-between gap-8">
      <div class="max-w-2xl">
        <span class="eyebrow reveal"><span class="size-1.5 rounded-full bg-violet"></span>The catalog</span>
        <h2 class="reveal mt-5 text-3xl md:text-4xl" data-delay="1">{curioCourses.length} courses. {totalScenes}+ animated scenes.</h2>
        <p class="reveal mt-4 text-muted" data-delay="2">
          Each course is a five-act story with its own guide character — {live.length} are live right
          now, free to preview.
        </p>
      </div>
      <dl class="reveal flex gap-8" data-delay="2">
        <div class="flex flex-col gap-1">
          <dt class="order-2 text-xs text-faint">Live previews</dt>
          <dd class="order-1 font-display text-3xl font-semibold text-ink">{live.length}</dd>
        </div>
        <div class="flex flex-col gap-1">
          <dt class="order-2 text-xs text-faint">Learn by doing</dt>
          <dd class="order-1 font-display text-3xl font-semibold text-ink">100%</dd>
        </div>
      </dl>
    </div>

    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {curioCourses.map((c, i) => (
        <article
          class="reveal group relative flex flex-col rounded-2xl border border-line bg-surface/30 p-6 transition-all duration-300 hover:-translate-y-1 hover:border-line-strong"
          data-delay={String((i % 3) + 1)}
        >
          <div class="flex items-start justify-between gap-3">
            <div
              class="grid size-12 place-items-center rounded-xl text-2xl ring-1 ring-inset"
              style={`background:color-mix(in oklab, ${c.accent} 12%, transparent); --tw-ring-color:color-mix(in oklab, ${c.accent} 35%, transparent)`}
            >
              {c.emoji}
            </div>
            {c.liveUrl ? (
              <span class="inline-flex items-center gap-1.5 rounded-full border border-teal/30 bg-teal/10 px-2.5 py-1 font-mono text-[0.6rem] uppercase tracking-[0.14em] text-teal">
                <span class="size-1.5 animate-pulse rounded-full bg-teal"></span>Live
              </span>
            ) : (
              <span class="rounded-full border border-line bg-white/[0.02] px-2.5 py-1 font-mono text-[0.6rem] uppercase tracking-[0.14em] text-faint">Soon</span>
            )}
          </div>

          <div class="mt-4 flex items-baseline gap-2.5">
            <h3 class="text-xl">{c.title}</h3>
            <span class="text-sm font-medium" style={`color:${c.accent}`}>{c.subject}</span>
          </div>
          <p class="mt-1 text-xs text-faint">Guided by {c.guide} · {c.scenes} scenes · {c.level}</p>

          <div class="mt-4 flex flex-wrap gap-1.5">
            {c.topics.map((t) => (
              <span class="rounded-full border border-line bg-white/[0.02] px-2.5 py-1 text-xs text-muted">{t}</span>
            ))}
          </div>

          {c.liveUrl && (
            <a
              href={c.liveUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-5 inline-flex items-center gap-2 text-sm font-medium text-body transition-colors group-hover:text-ink"
            >
              Preview live
              <Icon name="lucide:external-link" class="size-3.5 text-faint" />
            </a>
          )}
        </article>
      ))}
    </div>

    <div class="reveal mt-12 flex flex-wrap items-center gap-3">
      <Button href="https://volta-blush.vercel.app" size="lg" iconRight="external-link">Try Volta free</Button>
      <Button href="/contact" variant="secondary" size="lg">Join the launch waitlist</Button>
    </div>
  </div>
</section>

<script>
  // Three small canvas simulations in the Curio spirit. Pure 2D canvas — no deps.
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function setup(canvas: HTMLCanvasElement) {
    const ctx = canvas.getContext('2d')!;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const fit = () => {
      const r = canvas.getBoundingClientRect();
      canvas.width = r.width * dpr;
      canvas.height = r.height * dpr;
    };
    fit();
    new ResizeObserver(fit).observe(canvas);
    return { ctx, dpr };
  }

  /* Fade-trail helper: translucent dark wash instead of clearRect. */
  function wash(ctx: CanvasRenderingContext2D, w: number, h: number, a = 0.22) {
    ctx.globalCompositeOperation = 'source-over';
    ctx.fillStyle = `rgba(7, 8, 10, ${a})`;
    ctx.fillRect(0, 0, w, h);
  }

  function glowDot(ctx: CanvasRenderingContext2D, x: number, y: number, r: number, color: string) {
    ctx.shadowColor = color;
    ctx.shadowBlur = r * 4;
    ctx.fillStyle = color;
    ctx.beginPath();
    ctx.arc(x, y, r, 0, Math.PI * 2);
    ctx.fill();
    ctx.shadowBlur = 0;
  }

  /* ---- 1. Orbits (Cosmos) ---- */
  function orbit(canvas: HTMLCanvasElement) {
    const { ctx } = setup(canvas);
    const planets = [
      { a: 0.18, e: 0.0, size: 3.2, speed: 1.6, color: '#8ac2ff', th: Math.random() * 6.28 },
      { a: 0.3, e: 0.25, size: 4.2, speed: 0.9, color: '#2dd4bf', th: Math.random() * 6.28 },
      { a: 0.42, e: 0.12, size: 3.6, speed: 0.55, color: '#a78bfa', th: Math.random() * 6.28 },
    ];
    let t = 0;
    const frame = () => {
      const w = canvas.width, h = canvas.height;
      const cx = w / 2, cy = h / 2, R = Math.min(w, h);
      wash(ctx, w, h, 0.16);
      // star
      const pulse = 1 + Math.sin(t * 2) * 0.08;
      glowDot(ctx, cx, cy, R * 0.022 * pulse, '#fbbf24');
      ctx.globalCompositeOperation = 'lighter';
      for (const p of planets) {
        p.th += p.speed * 0.012 * (reduce ? 0 : 1);
        // ellipse with star at focus (Kepler-ish look)
        const r = (p.a * R * (1 - p.e * p.e)) / (1 + p.e * Math.cos(p.th));
        const x = cx + r * Math.cos(p.th);
        const y = cy + r * Math.sin(p.th) * 0.92;
        glowDot(ctx, x, y, p.size * (R / 420), p.color);
      }
      t += 0.016;
      if (!reduce) requestAnimationFrame(frame);
    };
    // pre-darken the canvas fully once
    ctx.fillStyle = '#07080a';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    if (reduce) { for (let i = 0; i < 600; i++) frame(); }
    frame();
  }

  /* ---- 2. Prism (Light & optics) ---- */
  function prism(canvas: HTMLCanvasElement) {
    const { ctx } = setup(canvas);
    const SPECTRUM = ['#ff5c5c', '#ff8a4c', '#fbbf24', '#36d399', '#2dd4bf', '#4a9eff', '#a78bfa'];
    let t = 0;
    const frame = () => {
      const w = canvas.width, h = canvas.height;
      wash(ctx, w, h, 0.3);
      const cx = w * 0.5, cy = h * 0.52, s = Math.min(w, h) * 0.21;
      // prism triangle
      ctx.globalCompositeOperation = 'source-over';
      ctx.strokeStyle = 'rgba(244,247,251,0.55)';
      ctx.lineWidth = Math.max(1.2, w / 700);
      ctx.beginPath();
      ctx.moveTo(cx, cy - s);
      ctx.lineTo(cx - s * 0.95, cy + s * 0.75);
      ctx.lineTo(cx + s * 0.95, cy + s * 0.75);
      ctx.closePath();
      ctx.stroke();
      ctx.fillStyle = 'rgba(74,158,255,0.05)';
      ctx.fill();

      ctx.globalCompositeOperation = 'lighter';
      const entry = { x: cx - s * 0.42, y: cy + s * 0.1 };
      // incoming white beam with marching dashes
      const dash = (x0: number, y0: number, x1: number, y1: number, color: string, width: number) => {
        ctx.strokeStyle = color;
        ctx.lineWidth = width;
        ctx.setLineDash([10, 14]);
        ctx.lineDashOffset = -t * 60;
        ctx.shadowColor = color;
        ctx.shadowBlur = 8;
        ctx.beginPath();
        ctx.moveTo(x0, y0);
        ctx.lineTo(x1, y1);
        ctx.stroke();
        ctx.setLineDash([]);
        ctx.shadowBlur = 0;
      };
      dash(-10, cy - s * 0.32, entry.x, entry.y, 'rgba(244,247,251,0.85)', Math.max(2, w / 360));
      // fan of refracted rays
      SPECTRUM.forEach((c, i) => {
        const k = i / (SPECTRUM.length - 1) - 0.5;
        const ang = 0.18 + k * 0.5;
        const exit = { x: cx + s * 0.4, y: cy + s * 0.12 + k * s * 0.16 };
        // inside-prism segment (subtle)
        ctx.strokeStyle = 'rgba(244,247,251,0.10)';
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.moveTo(entry.x, entry.y);
        ctx.lineTo(exit.x, exit.y);
        ctx.stroke();
        dash(exit.x, exit.y, w + 10, exit.y + Math.tan(ang) * (w - exit.x), c, Math.max(1.6, w / 520));
      });
      t += reduce ? 0 : 0.016;
      if (!reduce) requestAnimationFrame(frame);
    };
    ctx.fillStyle = '#07080a';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    frame();
  }

  /* ---- 3. Circuit (Volta) ---- */
  function circuit(canvas: HTMLCanvasElement) {
    const { ctx } = setup(canvas);
    const N = 26;
    let t = 0;
    const frame = () => {
      const w = canvas.width, h = canvas.height;
      wash(ctx, w, h, 0.25);
      const m = Math.min(w, h) * 0.16;
      const x0 = m, y0 = m, x1 = w - m, y1 = h - m;
      const peri = 2 * (x1 - x0) + 2 * (y1 - y0);
      const current = 0.55 + 0.45 * Math.sin(t * 0.8); // slow breathing current
      // wire
      ctx.globalCompositeOperation = 'source-over';
      ctx.strokeStyle = 'rgba(244,247,251,0.28)';
      ctx.lineWidth = Math.max(1.5, w / 500);
      ctx.strokeRect(x0, y0, x1 - x0, y1 - y0);
      // battery (left mid)
      const by = (y0 + y1) / 2;
      ctx.strokeStyle = '#8ac2ff';
      ctx.lineWidth = Math.max(2, w / 380);
      ctx.beginPath();
      ctx.moveTo(x0 - m * 0.28, by - m * 0.34); ctx.lineTo(x0 + m * 0.28, by - m * 0.34);
      ctx.moveTo(x0 - m * 0.14, by - m * 0.1); ctx.lineTo(x0 + m * 0.14, by - m * 0.1);
      ctx.stroke();
      // lamp (right mid) glows with current
      ctx.globalCompositeOperation = 'lighter';
      const lampR = m * 0.3 * (0.8 + current * 0.45);
      glowDot(ctx, x1, by, lampR, `rgba(251,191,36,${0.35 + current * 0.6})`);
      // electrons marching around the loop
      const pos = (k: number) => {
        let d = ((k + (reduce ? 0 : t * 0.07 * current)) % 1) * peri;
        if (d < x1 - x0) return { x: x0 + d, y: y0 };
        d -= x1 - x0;
        if (d < y1 - y0) return { x: x1, y: y0 + d };
        d -= y1 - y0;
        if (d < x1 - x0) return { x: x1 - d, y: y1 };
        d -= x1 - x0;
        return { x: x0, y: y1 - d };
      };
      for (let i = 0; i < N; i++) {
        const p = pos(i / N);
        glowDot(ctx, p.x, p.y, Math.max(1.6, w / 420), '#2dd4bf');
      }
      t += reduce ? 0 : 0.016;
      if (!reduce) requestAnimationFrame(frame);
    };
    ctx.fillStyle = '#07080a';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    frame();
  }

  const starters: Record<string, (c: HTMLCanvasElement) => void> = { orbit, prism, circuit };
  document.querySelectorAll<HTMLCanvasElement>('canvas[data-demo]').forEach((c) => starters[c.dataset.demo!]?.(c));
</script>
