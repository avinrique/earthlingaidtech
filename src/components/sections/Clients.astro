---
import { clients } from '@/data/site';
---

<section class="border-y border-line bg-canvas-deep/50">
  <div class="container-app grid gap-10 py-14 lg:grid-cols-[auto_1fr] lg:items-center lg:gap-16">
    <p class="max-w-xs text-sm leading-relaxed text-faint">
      <span class="block font-mono text-xs uppercase tracking-[0.2em] text-muted">Selected clients</span>
      <span class="mt-2 block">From local teams to a restaurant group in Switzerland — work that shipped.</span>
    </p>

    <ul class="grid grid-cols-2 gap-x-8 gap-y-5 sm:grid-cols-3">
      {clients.map((c) => (
        <li class="flex flex-col border-l border-line pl-4">
          <span class="font-display text-lg font-semibold tracking-tight text-body">{c.name}</span>
          {c.note && <span class="mt-0.5 font-mono text-[0.65rem] uppercase tracking-wider text-dim">{c.note}</span>}
        </li>
      ))}
    </ul>
  </div>
</section>
