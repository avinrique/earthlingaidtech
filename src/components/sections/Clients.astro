---
import { clients } from '@/data/site';
const row = [...clients, ...clients];
---

<section class="border-y border-line bg-canvas-deep/50 py-14">
  <div class="container-app">
    <p class="text-center font-mono text-xs uppercase tracking-[0.2em] text-faint">
      Trusted by teams across education, public health, technology, and global business
    </p>
  </div>

  <div class="group relative mt-9 overflow-hidden [mask-image:linear-gradient(to_right,transparent,black_12%,black_88%,transparent)]">
    <div class="flex w-max animate-[marquee_36s_linear_infinite] items-center gap-12 pr-12 group-hover:[animation-play-state:paused]">
      {row.map((c) => (
        <div class="flex shrink-0 items-baseline gap-2">
          <span class="font-display text-xl font-semibold tracking-tight text-faint transition-colors duration-300 hover:text-ink">
            {c.name}
          </span>
          {c.note && <span class="font-mono text-[0.6rem] uppercase tracking-wider text-dim">{c.note}</span>}
        </div>
      ))}
    </div>
  </div>
</section>
