---
import SectionHeading from '../SectionHeading.astro';
import { approach } from '@/data/site';
---

<section id="approach" class="relative py-20 md:py-28">
  <div class="container-app">
    <SectionHeading
      eyebrow="How we work"
      title="From the real problem <span class='text-gradient'>to real impact</span>"
      subtitle="We start with the problem, not the technology — then engineer, ship, and keep evolving."
    />

    <ol class="mt-14 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {approach.map((s, i) => (
        <li
          class="reveal group relative flex flex-col rounded-2xl border border-line bg-surface/30 p-6 transition-colors duration-300 hover:border-line-strong"
          data-delay={String(i + 1)}
        >
          <span class="font-mono text-sm font-medium text-accent">{s.step}</span>
          <span class="mt-3 h-px w-full bg-gradient-to-r from-line-strong to-transparent"></span>
          <h3 class="mt-4 text-lg">{s.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted">{s.body}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
