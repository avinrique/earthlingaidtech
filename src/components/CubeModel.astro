---
/**
 * CubeModel — loads the real 3D brand mark (public/models/eat-cube.glb, built
 * in Blender from the nested-cube logo) with Three.js + GLTFLoader. The model
 * auto-rotates and follows the pointer; it renders on a transparent canvas over
 * a CSS glow. Falls back to the static SVG logo when WebGL is unavailable or the
 * user prefers reduced motion.
 */
import CubeLogo from './CubeLogo.astro';
---

<div class="cube3d" data-cube3d>
  <div class="cube3d__bg" aria-hidden="true">
    <span class="cube3d__ring cube3d__ring--1"></span>
    <span class="cube3d__ring cube3d__ring--2"></span>
    <span class="cube3d__glow"></span>
  </div>

  <canvas class="cube3d__canvas" data-cube-canvas aria-hidden="true"></canvas>

  <div class="cube3d__fallback" data-cube-fallback>
    <CubeLogo size={220} animated title="Earthling Aidtech" />
  </div>
</div>

<style>
  .cube3d {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    display: grid;
    place-items: center;
  }
  .cube3d__bg {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    pointer-events: none;
  }
  .cube3d__ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.06);
  }
  .cube3d__ring--1 { width: 86%; height: 86%; }
  .cube3d__ring--2 { width: 60%; height: 60%; border-color: rgba(74, 158, 255, 0.12); }
  .cube3d__glow {
    position: absolute;
    width: 64%;
    height: 64%;
    border-radius: 50%;
    background: radial-gradient(closest-side, rgba(74, 158, 255, 0.32), transparent 70%);
    filter: blur(12px);
    animation: cube3d-pulse 5s ease-in-out infinite;
  }
  .cube3d__canvas {
    position: relative;
    width: 100%;
    height: 100%;
    display: block;
    opacity: 0;
    transition: opacity 0.6s ease;
  }
  .cube3d__canvas[data-ready] { opacity: 1; }
  .cube3d__fallback {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    transition: opacity 0.5s ease;
  }
  .cube3d__fallback[data-hidden] { opacity: 0; pointer-events: none; }

  @keyframes cube3d-pulse {
    0%, 100% { opacity: 0.5; transform: scale(0.96); }
    50% { opacity: 0.95; transform: scale(1.06); }
  }
  @media (prefers-reduced-motion: reduce) {
    .cube3d__glow { animation: none; }
  }
</style>

<script>
  import * as THREE from 'three';
  import { GLTFLoader } from 'three/examples/jsm/loaders/GLTFLoader.js';

  const root = document.querySelector<HTMLElement>('[data-cube3d]');
  const canvas = root?.querySelector<HTMLCanvasElement>('[data-cube-canvas]');
  const fallback = root?.querySelector<HTMLElement>('[data-cube-fallback]');

  if (root && canvas) {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let renderer: THREE.WebGLRenderer | null = null;
    try {
      renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    } catch {
      renderer = null; // keep the SVG fallback
    }

    if (renderer) {
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.outputColorSpace = THREE.SRGBColorSpace;

      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(32, 1, 0.1, 100);
      camera.position.set(0, 0, 7);

      const pivot = new THREE.Group();
      scene.add(pivot);
      // Fixed pose set after load (looks down the nesting corner = the logo's
      // isometric view). No auto-rotation, no pointer-tilt — the only motion is
      // assemble-on-load and explode-on-hover.

      // Flat SVG-style model: the materials carry their own color (lightly
      // emissive), so we just need soft, even light to keep the tri-tone faces
      // reading true — no environment map / heavy reflections.
      scene.add(new THREE.AmbientLight(0xffffff, 0.85));
      const key = new THREE.DirectionalLight(0xffffff, 0.9);
      key.position.set(3, 5, 6);
      scene.add(key);
      const fill = new THREE.DirectionalLight(0xbcd4ff, 0.4);
      fill.position.set(-5, -2, 3);
      scene.add(fill);

      let model: THREE.Object3D | null = null;
      let coreMat: THREE.MeshStandardMaterial | null = null;

      // ---- assemble / explode separation state ----
      let outerNode: THREE.Object3D | null = null;
      let middleNode: THREE.Object3D | null = null;
      let coreNode: THREE.Object3D | null = null;
      const outerRest = new THREE.Vector3();
      const middleRest = new THREE.Vector3();
      const coreRest = new THREE.Vector3();
      const sepAxis = new THREE.Vector3();   // unit direction outer -> core
      let restDist = 0;                       // |coreRest - outerRest| (EatCube local space)
      const _tmp = new THREE.Vector3();       // scratch, no per-frame allocation

      let sep = 1;          // 1 = fully separated, 0 = assembled solid cube
      let sepTarget = 0;    // first visible frames ease 1 -> 0 (assemble on load)
      const SEP_LERP = 0.1; // damping toward sepTarget
      const Fm = 0.9;       // middle travel factor
      const Fc = 2.0;       // core travel factor (grows outward => telescoping)
      const EMISSIVE_BOOST = 0.9;

      // Position the three cubes for the current `sep` (0 = assembled, 1 = apart).
      const applySeparation = () => {
        if (!outerNode || !middleNode || !coreNode) return;
        outerNode.position.copy(outerRest);
        middleNode.position.copy(middleRest)
          .add(_tmp.copy(sepAxis).multiplyScalar(restDist * Fm * sep));
        coreNode.position.copy(coreRest)
          .add(_tmp.copy(sepAxis).multiplyScalar(restDist * Fc * sep));
      };

      const resize = () => {
        const s = root.clientWidth;
        if (!s) return;
        renderer!.setSize(s, s, false);
        camera.aspect = 1;
        camera.updateProjectionMatrix();
      };
      resize();
      new ResizeObserver(resize).observe(root);

      // ---- load the Blender model ----
      const url = `${import.meta.env.BASE_URL}models/eat-cube.glb`;
      new GLTFLoader().load(
        url,
        (gltf) => {
          model = gltf.scene;

          // center + frame the model to a consistent size
          const box = new THREE.Box3().setFromObject(model);
          const center = box.getCenter(new THREE.Vector3());
          const size = box.getSize(new THREE.Vector3()).length();
          model.position.sub(center);
          const scale = 4.6 / size;
          model.scale.setScalar(scale);

          // grab the three cube nodes + a core material to pulse/boost
          model.traverse((o) => {
            const name = o.name || '';
            if (name.includes('CubeOuter')) outerNode = o;
            else if (name.includes('CubeMiddle')) middleNode = o;
            else if (name.includes('CubeCore')) coreNode = o;

            const m = (o as THREE.Mesh).material as THREE.MeshStandardMaterial | undefined;
            if (m && m.name && m.name.toLowerCase().includes('core')) {
              coreMat = m;
              // GLB ships no emissive color; without this, emissiveIntensity is a no-op.
              m.emissive = new THREE.Color(0x2d7bff);
            }
          });

          // record rest (assembled) positions, then derive the separation axis +
          // magnitude from the geometry itself (orientation-proof)
          if (outerNode && middleNode && coreNode) {
            outerRest.copy(outerNode.position);
            middleRest.copy(middleNode.position);
            coreRest.copy(coreNode.position);
            sepAxis.copy(coreRest).sub(outerRest);
            restDist = sepAxis.length();
            if (restDist > 1e-6) sepAxis.multiplyScalar(1 / restDist);

            // Orient the cube so the nesting corner faces the camera (the logo's
            // isometric look): map the separation axis onto a direction toward
            // the viewer, with a slight upward tilt so the top face reads.
            const viewDir = new THREE.Vector3(0, 0.16, 1).normalize();
            pivot.quaternion.setFromUnitVectors(sepAxis, viewDir);
          }

          pivot.add(model);
          canvas.setAttribute('data-ready', '');
          fallback?.setAttribute('data-hidden', '');

          if (reduce) {
            // no animation: render the assembled solid cube once and stop
            sep = 0;
            sepTarget = 0;
            applySeparation();
            if (coreMat) coreMat.emissiveIntensity = 0.5;
            renderer!.render(scene, camera);
            return;
          }

          // animated path: start separated and let the loop ease it together
          sep = 1;
          sepTarget = 0;
          applySeparation();         // paint the exploded start state first (no flash)
          renderer!.render(scene, camera);
          if (visible) kick();
        },
        undefined,
        () => { /* load error → keep SVG fallback visible */ },
      );

      // ---- hover to explode (desktop pointers only); no rotation, no tilt ----
      const coarse = window.matchMedia('(pointer: coarse)').matches;
      if (!reduce && !coarse) {
        root.addEventListener('pointerenter', () => { sepTarget = 1; kick(); });
        root.addEventListener('pointerleave', () => { sepTarget = 0; kick(); });
      }

      // ---- render-on-demand: only renders while the cubes are moving ----
      // (assemble on load, explode/reassemble on hover). Idle = no rendering.
      let raf = 0;
      let running = false;
      let visible = true;
      const SEP_EPS = 1e-3;

      const draw = () => {
        if (!running) return;
        sep += (sepTarget - sep) * SEP_LERP;
        const moving = Math.abs(sep - sepTarget) > SEP_EPS;
        if (!moving) sep = sepTarget;             // settle exactly
        applySeparation();
        if (coreMat) coreMat.emissiveIntensity = 0.5 + EMISSIVE_BOOST * sep;
        renderer!.render(scene, camera);
        if (moving && visible) {
          raf = requestAnimationFrame(draw);
        } else {
          running = false;                         // at rest — stop (battery)
        }
      };

      function kick() {
        if (reduce || !model || !visible || running) return;
        running = true;
        raf = requestAnimationFrame(draw);
      }
      const stop = () => { running = false; cancelAnimationFrame(raf); };

      if ('IntersectionObserver' in window) {
        new IntersectionObserver((entries) => {
          visible = entries[0].isIntersecting;
          if (visible) kick(); else stop();
        }, { threshold: 0.05 }).observe(root);
      } else {
        kick();
      }

      window.addEventListener('pagehide', stop);
    }
  }
</script>
