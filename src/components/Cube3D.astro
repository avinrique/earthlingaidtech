---
/**
 * Cube3D — the signature hero element: a real CSS 3D cube built from six
 * glass faces with glowing brand edges, each carrying the nested-cube mark.
 * Auto-rotates, reacts to pointer movement (parallax), and falls back to a
 * static 3/4 pose under prefers-reduced-motion.
 *
 * Layering keeps CSS animation and JS parallax from fighting over `transform`:
 *   scene (perspective) → parallax (JS pointer) → cube (CSS spin) → faces
 */
import CubeLogo from './CubeLogo.astro';

const faces = [
  { t: 'rotateY(0deg)   translateZ(var(--h))', accent: 'accent' },
  { t: 'rotateY(180deg) translateZ(var(--h))', accent: 'accent' },
  { t: 'rotateY(90deg)  translateZ(var(--h))', accent: 'teal' },
  { t: 'rotateY(-90deg) translateZ(var(--h))', accent: 'teal' },
  { t: 'rotateX(90deg)  translateZ(var(--h))', accent: 'violet' },
  { t: 'rotateX(-90deg) translateZ(var(--h))', accent: 'violet' },
];

const accentRGB: Record<string, string> = {
  accent: '74, 158, 255',
  teal: '45, 212, 191',
  violet: '167, 139, 250',
};
---

<div class="cube-scene" aria-hidden="true">
  <!-- ambient glows + rings behind the cube -->
  <div class="cube-bg">
    <div class="cube-ring cube-ring--1"></div>
    <div class="cube-ring cube-ring--2"></div>
    <div class="cube-core"></div>
  </div>

  <div class="cube-parallax" data-cube-parallax>
    <div class="cube">
      {faces.map((f) => (
        <div class="cube-face" style={`--face-t:${f.t}; --rgb:${accentRGB[f.accent]}`}>
          <span class="cube-face__sheen"></span>
          <CubeLogo size={92} class="cube-face__mark" title="" />
        </div>
      ))}
    </div>
  </div>

  <!-- orbiting particles in front for depth -->
  <div class="cube-orbit">
    <span class="cube-dot cube-dot--a"></span>
    <span class="cube-dot cube-dot--b"></span>
    <span class="cube-dot cube-dot--c"></span>
  </div>
</div>

<style>
  .cube-scene {
    --cube: clamp(12rem, 15.5vw, 16rem);
    --h: calc(var(--cube) / 2);
    position: relative;
    display: grid;
    place-items: center;
    width: 100%;
    aspect-ratio: 1;
    perspective: 1100px;
    perspective-origin: 50% 45%;
  }

  /* ---- background glow + rings ---- */
  .cube-bg {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    pointer-events: none;
  }
  .cube-ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.06);
  }
  .cube-ring--1 { width: 88%; height: 88%; }
  .cube-ring--2 { width: 64%; height: 64%; border-color: rgba(74, 158, 255, 0.12); }
  .cube-core {
    position: absolute;
    width: 60%;
    height: 60%;
    border-radius: 50%;
    background: radial-gradient(closest-side, rgba(74, 158, 255, 0.28), transparent 70%);
    filter: blur(8px);
    animation: cube-core-pulse 5s ease-in-out infinite;
  }

  /* ---- parallax + spin layers ---- */
  .cube-parallax {
    position: relative;
    width: var(--cube);
    height: var(--cube);
    transform-style: preserve-3d;
    transform: rotateX(var(--my, -14deg)) rotateY(var(--mx, 22deg));
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .cube {
    position: absolute;
    inset: 0;
    transform-style: preserve-3d;
    animation: cube-spin 26s linear infinite;
    will-change: transform;
  }

  /* ---- faces ---- */
  .cube-face {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    transform: var(--face-t);
    border: 1px solid rgba(var(--rgb), 0.55);
    border-radius: 12px;
    background:
      linear-gradient(140deg, rgba(var(--rgb), 0.1), rgba(11, 13, 16, 0.42) 70%);
    box-shadow:
      inset 0 0 44px rgba(var(--rgb), 0.14),
      inset 0 0 1px rgba(var(--rgb), 0.8),
      0 0 26px rgba(var(--rgb), 0.12);
    backface-visibility: visible;
    overflow: hidden;
  }
  .cube-face__sheen {
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, transparent 35%, rgba(255, 255, 255, 0.08) 50%, transparent 65%);
  }
  .cube-face :global(.cube-face__mark) {
    opacity: 0.92;
    filter: drop-shadow(0 6px 14px rgba(0, 0, 0, 0.5));
  }
  /* corner ticks for a techy, engineered feel */
  .cube-face::before,
  .cube-face::after {
    content: '';
    position: absolute;
    width: 14px;
    height: 14px;
    border: 1px solid rgba(var(--rgb), 0.85);
  }
  .cube-face::before { top: 8px; left: 8px; border-right: 0; border-bottom: 0; }
  .cube-face::after { bottom: 8px; right: 8px; border-left: 0; border-top: 0; }

  /* ---- orbiting particles ---- */
  .cube-orbit {
    position: absolute;
    inset: 0;
    pointer-events: none;
    animation: cube-spin 18s linear infinite reverse;
  }
  .cube-dot {
    position: absolute;
    border-radius: 50%;
  }
  .cube-dot--a {
    top: 4%; left: 50%;
    width: 10px; height: 10px;
    background: #4a9eff;
    box-shadow: 0 0 16px 3px rgba(74, 158, 255, 0.7);
  }
  .cube-dot--b {
    bottom: 12%; right: 10%;
    width: 8px; height: 8px;
    background: #2dd4bf;
    box-shadow: 0 0 14px 3px rgba(45, 212, 191, 0.6);
  }
  .cube-dot--c {
    bottom: 20%; left: 8%;
    width: 6px; height: 6px;
    background: #a78bfa;
    box-shadow: 0 0 12px 3px rgba(167, 139, 250, 0.6);
  }

  @keyframes cube-spin {
    from { transform: rotateX(-18deg) rotateY(0deg); }
    to   { transform: rotateX(-18deg) rotateY(360deg); }
  }
  @keyframes cube-core-pulse {
    0%, 100% { opacity: 0.55; transform: scale(0.96); }
    50%      { opacity: 1;    transform: scale(1.06); }
  }

  @media (prefers-reduced-motion: reduce) {
    .cube,
    .cube-orbit,
    .cube-core {
      animation: none;
    }
    .cube {
      transform: rotateX(-20deg) rotateY(28deg);
    }
  }
</style>

<script>
  // Pointer parallax — tilts the cube toward the cursor. Disabled for
  // reduced-motion and coarse (touch) pointers.
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const coarse = window.matchMedia('(pointer: coarse)').matches;
  const el = document.querySelector<HTMLElement>('[data-cube-parallax]');

  if (el && !reduce && !coarse) {
    let raf = 0;
    const onMove = (e: PointerEvent) => {
      if (raf) return;
      raf = requestAnimationFrame(() => {
        raf = 0;
        const x = e.clientX / window.innerWidth - 0.5;
        const y = e.clientY / window.innerHeight - 0.5;
        el.style.setProperty('--mx', `${(x * 30 + 22).toFixed(2)}deg`);
        el.style.setProperty('--my', `${(-y * 24 - 14).toFixed(2)}deg`);
      });
    };
    window.addEventListener('pointermove', onMove, { passive: true });
  }
</script>
