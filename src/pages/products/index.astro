---
import Base from '@/layouts/Base.astro';
import PageHeader from '@/components/PageHeader.astro';
import ProductsShowcase from '@/components/sections/ProductsShowcase.astro';
import { Icon } from 'astro-icon/components';
import { products } from '@/data/site';

const labProjects = products.filter((p) => p.lowKey);

const accentText: Record<string, string> = {
  accent: 'text-accent',
  teal: 'text-teal',
  violet: 'text-violet',
  amber: 'text-amber',
};
---

<Base
  title="Products"
  description="Products engineered by Earthling Aidtech — from Prepzer0, our AI examination platform live in classrooms, to Curio interactive courses and the PrintFlow self-service print kiosk."
>
  <PageHeader
    eyebrow="Products"
    title="Tools we've <span class='text-gradient'>shipped</span>"
    subtitle="A product-first company building software and physical systems that institutions and teams rely on — designed, engineered, and run by us."
  />
  <ProductsShowcase heading={false} />

  {labProjects.length > 0 && (
    <section class="pb-24">
      <div class="container-app">
        <p class="reveal font-mono text-xs uppercase tracking-[0.18em] text-faint">From the lab</p>
        <p class="reveal mt-3 max-w-2xl text-muted" data-delay="1">
          Side projects we run at production scale — built for fun, kept honest by real users.
        </p>
        <div class:list={['mt-6 grid gap-4', labProjects.length > 1 ? 'sm:grid-cols-2' : 'max-w-xl']}>
          {labProjects.map((p) => (
            <a
              href={`/products/${p.slug}`}
              class="reveal group flex items-center gap-4 rounded-2xl border border-line bg-surface/30 p-6 transition-all duration-300 hover:-translate-y-1 hover:border-line-strong"
              data-delay="2"
            >
              <div class="grid size-12 shrink-0 place-items-center rounded-xl bg-white/[0.03] ring-1 ring-inset ring-line-strong">
                <Icon name={`lucide:${p.icon}`} class:list={['size-6', accentText[p.accent]]} />
              </div>
              <div class="min-w-0">
                <div class="flex items-center gap-3">
                  <h3 class="text-base">{p.name}</h3>
                  <span class="font-mono text-[0.6rem] uppercase tracking-[0.14em] text-faint">{p.status}</span>
                </div>
                <p class="mt-0.5 truncate text-sm text-faint">{p.kicker}</p>
              </div>
              <Icon name="lucide:arrow-right" class="ml-auto size-5 shrink-0 text-faint transition-transform group-hover:translate-x-1" />
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Base>
