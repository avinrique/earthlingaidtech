---
import Base from '@/layouts/Base.astro';
import PageHeader from '@/components/PageHeader.astro';
import { Icon } from 'astro-icon/components';
import { workshops } from '@/data/site';

const domainIcons: Record<string, string> = {
  'Web Development': 'globe',
  'Application Development': 'smartphone',
  'Artificial Intelligence & Agentic AI': 'bot',
  'Automation & Scripting': 'workflow',
  'Robotics & Embedded Systems': 'cpu',
};
---

<Base
  title="Workshops & Training"
  description="Hands-on workshops and technical training for students and institutions — web, AI, automation, and robotics. 600+ students trained across BMSIT and SVIT."
>
  <PageHeader
    eyebrow="Workshops & training"
    title="Hands-on training that builds <span class='text-gradient'>real skills</span>"
    subtitle="Practical programs for students and institutions across a broad range of technical domains — emphasizing real-world use cases and industry-aligned skills."
  />

  <!-- Stats -->
  <section class="py-16">
    <div class="container-app">
      <dl class="grid grid-cols-1 gap-4 sm:grid-cols-3">
        {workshops.stats.map((s, i) => (
          <div class="reveal rounded-2xl border border-line bg-surface/30 p-7 text-center" data-delay={String(i + 1)}>
            <dd class="font-display text-4xl font-semibold text-ink md:text-5xl">{s.value}</dd>
            <dt class="mt-2 text-sm text-faint">{s.label}</dt>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- Domains -->
  <section class="py-12 md:py-16">
    <div class="container-app">
      <h2 class="reveal text-3xl md:text-4xl">Workshop domains</h2>
      <p class="reveal mt-3 max-w-xl text-muted" data-delay="1">
        Every program emphasizes practical implementation, real-world use cases, and industry-aligned
        skills.
      </p>

      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {workshops.domains.map((d, i) => (
          <div
            class="reveal group flex items-center gap-4 rounded-2xl border border-line bg-surface/30 p-6 transition-all duration-300 hover:-translate-y-1 hover:border-line-strong"
            data-delay={String((i % 3) + 1)}
          >
            <div class="grid size-11 shrink-0 place-items-center rounded-xl bg-white/[0.03] ring-1 ring-inset ring-line-strong transition-colors group-hover:ring-accent/30">
              <Icon name={`lucide:${domainIcons[d] ?? 'sparkles'}`} class="size-5 text-accent" />
            </div>
            <span class="font-medium text-body">{d}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Institutions -->
  <section class="py-12 md:py-20">
    <div class="container-app">
      <div class="reveal rounded-3xl border border-line bg-surface/40 p-8 md:p-12">
        <p class="font-mono text-xs uppercase tracking-[0.18em] text-faint">Institutions we've worked with</p>
        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          {workshops.institutions.map((inst) => (
            <div class="flex items-center gap-3 rounded-2xl border border-line bg-white/[0.02] p-5">
              <Icon name="lucide:building-2" class="size-6 shrink-0 text-accent" />
              <span class="font-display text-lg font-medium text-ink">{inst}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</Base>
